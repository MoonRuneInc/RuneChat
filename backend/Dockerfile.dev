FROM rust:1-alpine AS chef
RUN apk add --no-cache musl-dev pkgconfig openssl-dev
RUN cargo install cargo-chef --locked
WORKDIR /app

FROM chef AS planner
COPY Cargo.toml Cargo.lock ./
COPY backend/Cargo.toml ./backend/
COPY frontend/src-tauri/Cargo.toml ./frontend/src-tauri/
RUN mkdir -p backend/src frontend/src-tauri/src \
    && echo "fn main(){}" > backend/src/main.rs \
    && echo "pub fn run(){}" > frontend/src-tauri/src/lib.rs
RUN cargo chef prepare --recipe-path recipe.json

FROM chef AS cacher
COPY Cargo.toml Cargo.lock ./
COPY frontend/src-tauri/Cargo.toml ./frontend/src-tauri/
RUN mkdir -p frontend/src-tauri/src \
    && echo "pub fn run(){}" > frontend/src-tauri/src/lib.rs
COPY --from=planner /app/recipe.json recipe.json
RUN cargo chef cook -p runechat-backend --recipe-path recipe.json

FROM chef AS builder
COPY Cargo.toml Cargo.lock ./
COPY --from=cacher /app/target ./target
COPY backend/ ./backend/
COPY frontend/src-tauri/Cargo.toml ./frontend/src-tauri/
RUN mkdir -p frontend/src-tauri/src \
    && echo "pub fn run(){}" > frontend/src-tauri/src/lib.rs
RUN cargo build -p runechat-backend

FROM alpine:3.23
RUN apk add --no-cache ca-certificates
COPY --from=builder /app/target/debug/runechat-backend /usr/local/bin/runechat
EXPOSE 3000
CMD ["runechat"]
