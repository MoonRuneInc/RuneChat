# PostgreSQL
DATABASE_URL=postgres://cauldron:cauldron@db:5432/cauldron

# Redis
REDIS_URL=redis://redis:6379

# JWT — generate with: openssl rand -hex 64
JWT_SECRET=

# Token expiry
JWT_EXPIRY_SECONDS=900
REFRESH_TOKEN_EXPIRY_DAYS=7

# TOTP — AES-256-GCM key, 32 bytes base64-encoded
# Generate with: openssl rand -base64 32
TOTP_ENCRYPTION_KEY=
TOTP_ISSUER=Cauldron

# Domain
DOMAIN=chat.moonrune.cc

# SMTP (optional — required for email OTP unlock)
# SMTP_HOST=smtp.sendgrid.net
# SMTP_USERNAME=apikey
# SMTP_PASSWORD=
# SMTP_FROM=Cauldron <noreply@moonrune.cc>

# Logging
RUST_LOG=info
