{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Cauldron",
  "version": "0.1.4",
  "identifier": "cc.moonrune.cauldron",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Cauldron",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "devtools": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "createUpdaterArtifacts": false,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "minSdkVersion": 24
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDk4QkRFODJBMDQzREFGRTgKUldUb3J6MEVLdWk5bUdWOHhZbzRVOFpVbGFuamwwZi9wVHo2WUxMa3N3a0dOZXZpQU40Z3czY1IK",
      "endpoints": [
        "https://chat.moonrune.cc/updates.json"
      ]
    }
  }
}
