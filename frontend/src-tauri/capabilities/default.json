{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "http:default",
    {
      "identifier": "http:allow-fetch",
      "allow": [
        {
          "url": "http://localhost:3000"
        },
        {
          "url": "http://localhost:3000/*"
        },
        {
          "url": "https://*"
        },
        {
          "url": "wss://*"
        },
        {
          "url": "ws://*"
        }
      ]
    },
    "websocket:default"
  ]
}
