# Cauldron — Production Environment Variables
#
# Copy to .env.prod and fill in all REQUIRED values before deploying.
# Do NOT commit .env.prod to version control.

# ---------------------------------------------------------------------------
# REQUIRED
# ---------------------------------------------------------------------------

# Managed PostgreSQL connection string.
# Example: postgres://cauldron:PASSWORD@db.host.name:5432/cauldron
DATABASE_URL=

# JWT signing secret — must be at least 32 bytes.
# Generate with: openssl rand -hex 64
JWT_SECRET=

# TOTP encryption key — AES-256-GCM, 32 bytes base64-encoded.
# Generate with: openssl rand -base64 32
TOTP_ENCRYPTION_KEY=

# Public domain — used for CORS, WebSocket origin checks, and TOTP issuer.
DOMAIN=chat.moonrune.cc

# ---------------------------------------------------------------------------
# RECOMMENDED
# ---------------------------------------------------------------------------

# Redis URL — internal Docker network by default.
REDIS_URL=redis://redis:6379

# JWT expiry (seconds) and refresh token lifetime (days).
JWT_EXPIRY_SECONDS=900
REFRESH_TOKEN_EXPIRY_DAYS=7

# TOTP display name in authenticator apps.
TOTP_ISSUER=Cauldron

# ---------------------------------------------------------------------------
# OPTIONAL — only if email OTP unlock is enabled
# ---------------------------------------------------------------------------

# SMTP_HOST=smtp.sendgrid.net
# SMTP_USERNAME=apikey
# SMTP_PASSWORD=
# SMTP_FROM=Cauldron <noreply@moonrune.cc>

# ---------------------------------------------------------------------------
# OPERATIONAL
# ---------------------------------------------------------------------------

# Logging level for the Rust backend.
RUST_LOG=info
